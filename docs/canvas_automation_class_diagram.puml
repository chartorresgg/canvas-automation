hide empty members

' =============================================================================
' CAPA DE DOMINIO
' =============================================================================

package "Dominio" #EEF2FF {

  ' ── Enumeraciones ──────────────────────────────────────────────────────────

  enum CourseOption <<enumeration>> #C5CAE9 {
    NEW = "new"
    EXISTING = "existing"
  }

  enum EventStatus <<enumeration>> #C5CAE9 {
    PENDING
    RUNNING
    COMPLETED
    FAILED
    CANCELLED
  }

  ' ── Value Objects ──────────────────────────────────────────────────────────

  class DeploymentConfig <<value object>> {
    + zip_path: Path
    + course_option: CourseOption
    + course_name: str | None
    + template_id: int | None
    + course_id: int | None
    + excel_path: Path | None
    ..
    + is_new_course: bool
    + requires_front_page_update: bool
    + validar_campos_segun_opcion(): DeploymentConfig
    + validar_rutas_existen(): DeploymentConfig
  }

  class ProgressEvent <<value object>> {
    + step: int
    + total_steps: int
    + message: str
    + percentage: float
    + status: EventStatus
    + detail: str | None
    + course_id: int | None
    + error: str | None
    ..
    + {static} iniciando(): ProgressEvent
    + {static} curso_listo(course_id): ProgressEvent
    + {static} zip_procesado(course_id, cambios): ProgressEvent
    + {static} archivos_subidos(course_id, total): ProgressEvent
    + {static} paginas_actualizadas(course_id): ProgressEvent
    + {static} completado(course_id): ProgressEvent
    + {static} fallido(step, message, error): ProgressEvent
    + {static} cancelado(step): ProgressEvent
    + is_terminal: bool
    + step_label: str
    + to_sse_data(): str
  }

  ' ── Interface (Strategy) ───────────────────────────────────────────────────

  interface IPageComposer <<interface>> {
    + compose(course_id: int, ctx: dict): str
  }

  ' ── Servicios de dominio ───────────────────────────────────────────────────

  class ZipProcessor <<service>> {
    - zip_path: Path
    - extract_dir: Path
    - normalizer: FileNormalizer
    ..
    + extract(): ExtractionResult
    + normalize(): ProcessResult
    + cleanup(): None
    + content_path: Path
  }

  class FileNormalizer <<service>> {
    + normalize_folders(path: Path): NormalizationResult
    + normalize_pdfs(path: Path): NormalizationResult
    + es_nombre_canonico(nombre: str): bool
    - _canonizar_nombre(nombre: str): str
  }

  class InteractiveContentDetector <<service>> {
    + detect(files_map: dict): dict[int, list[dict]]
    - {static} _parsear_carpeta(carpeta: str): tuple | None
  }

  class GuionExcelReader <<service>> {
    - excel_path: Path
    ..
    + read(): GuionData
    - _extraer_url(texto: str): str | None
    - _parsear_unidades(ws): dict[int, UnidadGuion]
    - _buscar_fila(ws, etiqueta: str): str
  }

  class GuionData <<dataclass>> {
    + video_inicial_url: str | None
    + texto_inicio: str
    + texto_cierre: str
    + unidades: dict[int, UnidadGuion]
    ..
    + unidad(numero: int): UnidadGuion
  }

  class UnidadGuion <<dataclass>> {
    + numero: int
    + video_intro_url: str | None
    + parrafo_intro: str
    + podcast_url: str | None
    + vimeo_mat_fund_url: str | None
  }

}

' Relaciones dentro del dominio
DeploymentConfig --> CourseOption : usa >
ProgressEvent --> EventStatus : usa >
ZipProcessor --> FileNormalizer : delega normalización >
GuionExcelReader --> GuionData : crea >
GuionData "1" *-- "0..4" UnidadGuion : contiene >

' =============================================================================
' CAPA DE APLICACIÓN
' =============================================================================

package "Aplicación" #E8F5E9 {

  class DeploymentOrchestrator <<Facade>> {
    - _course_repo: CourseRepository
    - _file_repo: FileRepository
    - _page_repo: PageRepository
    - _detector: InteractiveContentDetector
    - _factory: PageComposerFactory
    - _tmp_dir: Path
    ..
    + deploy(config: DeploymentConfig): AsyncGenerator[ProgressEvent]
    - _setup_course(config): CourseInfo
    - _subir_archivos_con_eventos(course_id, path): UploadSummary
    - _actualizar_paginas(course_info, files_map, interactive_map, config): None
    - _actualizar_front(course_id, name, config): None
    - _vincular_pdfs(course_id, files_map, config): None
    - _construir_ctx_material_fundamental(...): dict
    - {static} _buscar_complemento(unidad, files_map): int | None
    - {static} _extraer_secuencia(nombre): int
  }

}

' Relaciones Facade → dominio
DeploymentOrchestrator --> DeploymentConfig : recibe >
DeploymentOrchestrator ..> ProgressEvent : yield >
DeploymentOrchestrator --> ZipProcessor : usa >
DeploymentOrchestrator --> InteractiveContentDetector : usa >
DeploymentOrchestrator --> GuionExcelReader : usa (Sprint 3) >

' =============================================================================
' CAPA DE INFRAESTRUCTURA — Canvas API
' =============================================================================

package "Infraestructura — Canvas API" #E3F2FD {

  ' ── Excepciones de dominio ─────────────────────────────────────────────────

  class CanvasAuthError <<exception>> {
    + message: str
  }
  class CanvasNotFoundError <<exception>> {
    + message: str
  }
  class CanvasRateLimitError <<exception>> {
    + message: str
  }
  class CanvasServerError <<exception>> {
    + message: str
  }

  ' ── Cliente HTTP ───────────────────────────────────────────────────────────

  class CanvasHttpClient <<HTTP Client>> {
    - _base_url: str
    - _token: str
    - _client: httpx.AsyncClient
    + account_id: int
    ..
    + get(endpoint: str, **kw): dict
    + post(endpoint: str, **kw): dict
    + put(endpoint: str, **kw): dict
    + get_paginated(endpoint: str, params): list[dict]
    - _request(method, endpoint, **kw): dict
    - _manejar_error(response): None
    - _obtener_cliente(): httpx.AsyncClient
    + __aenter__(): CanvasHttpClient
    + __aexit__(...): None
  }

  ' ── Repositorios ───────────────────────────────────────────────────────────

  class CourseRepository <<Repository>> {
    - _http: CanvasHttpClient
    ..
    + create_course(name: str): CourseInfo
    + copy_template(src_id: int, dst_id: int): MigrationResult
    + poll_migration(course_id, migration_id, timeout_seg, poll_interval): MigrationResult
    + get_course(course_id: int): CourseInfo
    + list_assignments(course_id: int): list[dict]
  }

  class FileRepository <<Repository>> {
    - _http: CanvasHttpClient
    ..
    + upload_all(course_id, content_path, on_progress): UploadSummary
    + upload_one(course_id, file_path, relative_path): ArchivoSubido
    - _subir_con_reintentos(course_id, ruta_abs, ruta_rel, summary): bool
    - _subir_binario(upload_url, upload_params, contenido, ...): int
    - {static} _listar_archivos(content_path): list[tuple]
    - {static} _detectar_content_type(file_path): str
  }

  class PageRepository <<Repository>> {
    - _http: CanvasHttpClient
    ..
    + update_page(course_id, page_slug, html): PageInfo
    + create_page(course_id, title, html, slug): PageInfo
    + update_or_create_page(course_id, page_slug, title, html): PageInfo
    + list_pages(course_id): list[PageInfo]
    + get_page(course_id, page_slug): PageInfo
    + link_pdf_to_assignment(course_id, assignment_id, assignment_name, file_id, filename): AssignmentLinkResult
    + link_pdfs_bulk(course_id, assignments, files_map, modelo, nivel): list[AssignmentLinkResult]
    - _generar_html_pdf_inline(course_id, file_id, filename): str
    - {static} _indexar_pdfs(files_map): dict
    - {static} _encontrar_pdf_para_actividad(...): tuple | None
  }

  ' ── Value Objects de resultado ─────────────────────────────────────────────

  class CourseInfo <<value object>> {
    + id: int
    + name: str
    + course_code: str
    + workflow_state: str
    + url: str
    ..
    + {static} desde_respuesta_canvas(data): CourseInfo
  }

  class MigrationResult <<value object>> {
    + migration_id: int
    + course_id: int
    + workflow_state: str
    + completada: bool
    ..
    + fallida: bool
  }

  class UploadSummary <<dataclass>> {
    + exitosos: dict[str, int]
    + fallidos: list[str]
    ..
    + total_exitosos: int
    + total_fallidos: int
    + total_archivos: int
    + porcentaje_exito: float
    + todo_exitoso: bool
  }

  class ArchivoSubido <<value object>> {
    + file_id: int
    + nombre: str
    + ruta_relativa: str
    + size_bytes: int
    + content_type: str
    + url_descarga: str
  }

  class PageInfo <<value object>> {
    + url: str
    + title: str
    + course_id: int
    + edit_url: str
    ..
    + {static} desde_respuesta_canvas(data, course_id): PageInfo
  }

  class AssignmentLinkResult <<value object>> {
    + assignment_id: int
    + assignment_name: str
    + file_id: int
    + vinculado: bool
    + motivo_fallo: str | None
  }

  class MigrationTimeoutError <<exception>> {
    + message: str
  }

  class MigrationFailedError <<exception>> {
    + message: str
  }

  class FileUploadError <<exception>> {
    + message: str
  }

}

' Relaciones de repositorios
CourseRepository --> CanvasHttpClient : usa >
FileRepository --> CanvasHttpClient : usa >
PageRepository --> CanvasHttpClient : usa >
CourseRepository ..> CourseInfo : crea >
CourseRepository ..> MigrationResult : crea >
FileRepository ..> UploadSummary : crea >
FileRepository ..> ArchivoSubido : crea >
PageRepository ..> PageInfo : crea >
PageRepository ..> AssignmentLinkResult : crea >
CourseRepository ..> MigrationTimeoutError : lanza >
CourseRepository ..> MigrationFailedError : lanza >
FileRepository ..> FileUploadError : lanza >
CanvasHttpClient ..> CanvasAuthError : lanza >
CanvasHttpClient ..> CanvasNotFoundError : lanza >
CanvasHttpClient ..> CanvasRateLimitError : lanza >
CanvasHttpClient ..> CanvasServerError : lanza >

' Facade → Repositorios
DeploymentOrchestrator --> CourseRepository : coordina >
DeploymentOrchestrator --> FileRepository : coordina >
DeploymentOrchestrator --> PageRepository : coordina >

' =============================================================================
' CAPA DE INFRAESTRUCTURA — Composers
' =============================================================================

package "Infraestructura — Composers" #FFF8E1 {

  ' ── Constantes de tipo ─────────────────────────────────────────────────────

  class PageType <<constants>> {
    + {static} IFRAME: str = "iframe"
    + {static} MATERIAL_FUNDAMENTAL: str = "material_fundamental"
    + {static} COMPLEMENTARY: str = "complementary"
    + {static} FRONT: str = "front"
    + {static} MATERIAL_DE_TRABAJO: str = "material_de_trabajo"
  }

  ' ── Factory ────────────────────────────────────────────────────────────────

  class PageComposerFactory <<Factory>> {
    - _registry: dict[str, type[IPageComposer]]
    ..
    + create(page_type: str): IPageComposer
    + register(page_type: str, composer_class: type): None
    + tipos_registrados(): list[str]
  }

  ' ── Implementaciones Strategy ──────────────────────────────────────────────

  class IframeComposer <<Strategy>> {
    + compose(course_id: int, ctx: dict): str
    ' ctx: {file_id: int}
  }

  class MaterialFundamentalComposer <<Strategy>> {
    + compose(course_id: int, ctx: dict): str
    - {static} _banner(): str
    - {static} _boton_archivo(course_id, file_id, titulo, imagen_url): str
    - {static} _boton_video_externo(url, titulo, imagen_url): str
    - {static} _boton_pagina_canvas(course_id, page_url, titulo, imagen_url): str
    - {static} _embed_vimeo(vimeo_url, titulo): str
    - {static} _embed_podcast(soundcloud_url): str
    - {static} _imagen_actividad(tipo, unidad): str
  }

  class ComplementaryPageComposer <<Strategy>> {
    + compose(course_id: int, ctx: dict): str
    ' ctx: {unidad, file_id, filename}
  }

  class FrontPageComposer <<Strategy>> {
    + compose(course_id: int, ctx: dict): str
    - {static} _reemplazar_modulo(html, modulo, nuevo_texto): str
    - {static} _template_base(): str
  }

  class MaterialDeTrabajoComposer <<Strategy>> {
    + compose(course_id: int, ctx: dict): str
    ' ctx: {pdfs: list[{file_id, unidad}]}
  }

}

' Strategy pattern: composers implementan IPageComposer
IframeComposer ..|> IPageComposer : implements
MaterialFundamentalComposer ..|> IPageComposer : implements
ComplementaryPageComposer ..|> IPageComposer : implements
FrontPageComposer ..|> IPageComposer : implements
MaterialDeTrabajoComposer ..|> IPageComposer : implements

' Factory crea IPageComposer
PageComposerFactory ..> IPageComposer : crea >
PageComposerFactory --> PageType : usa >

' Orchestrator usa factory
DeploymentOrchestrator --> PageComposerFactory : usa >

' =============================================================================
' CAPA DE PRESENTACIÓN — Backend FastAPI
' =============================================================================

package "Presentación — Backend FastAPI" #FBE9E7 {

  class TaskEntry <<dataclass>> {
    + task_id: str
    + queue: asyncio.Queue
    + creada_en: datetime
    + completada: bool
  }

  class TaskManager <<in-memory broker>> {
    - _tasks: dict[str, TaskEntry]
    ..
    + registrar(task_id: str): asyncio.Queue
    + obtener_queue(task_id: str): asyncio.Queue | None
    + marcar_completada(task_id: str): None
    + existe(task_id: str): bool
    + limpiar_completadas(): int
  }

  class DeployStartResponse <<Schema Pydantic>> {
    + task_id: str
    + stream_url: str
    + message: str
  }

  class ProgressEventSchema <<Schema Pydantic>> {
    + step: int
    + total_steps: int
    + message: str
    + percentage: float
    + status: str
    + detail: str | None
    + course_id: int | None
    + error: str | None
  }

  class DeployRouter <<Router FastAPI>> {
    ' POST /api/v1/deploy
    + iniciar_deploy(zip_file, excel_file, course_option, ...): DeployStartResponse
    ' GET /api/v1/deploy/stream/{task_id}
    + stream_progreso(task_id: str): StreamingResponse
    ' POST /api/v1/deploy/upload
    + upload_zip(zip_file, excel_file): JSONResponse
    ..
    - _ejecutar_deploy_background(task_id, config, queue): None
    - _generar_stream_sse(task_id, queue): AsyncGenerator
  }

  class HealthRouter <<Router FastAPI>> {
    ' GET /api/v1/health
    + health_check(): dict
  }

}

' Relaciones presentación backend
TaskManager "1" *-- "*" TaskEntry : gestiona >
DeployRouter --> TaskManager : usa >
DeployRouter --> DeploymentOrchestrator : invoca >
DeployRouter ..> DeployStartResponse : retorna >
DeployRouter ..> ProgressEvent : consume y transmite >

' =============================================================================
' CAPA DE PRESENTACIÓN — Frontend React / TypeScript
' =============================================================================

package "Presentación — Frontend React" #FCE4EC {

  class DeployPage <<React.Component>> {
    - state: DeployWizardState
    - mode: "wizard" | "deploying"
    - taskId: string | null
    - deploying: boolean
    - deployError: string | null
    ..
    + handleUploadSuccess(result, files): void
    + handleTemplateSelect(selection): void
    + handleMetadataComplete(metadata): void
    + handleIniciarDeploy(): Promise<void>
    + handleRetry(): void
    + handleNewDeploy(): void
  }

  class DropZone <<React.Component>> {
    - uploadState: UploadState
    - isDragging: boolean
    - progress: number
    - files: UploadedFiles | null
    - error: string | null
    ..
    + handleDragOver(e): void
    + handleDrop(e): void
    + handleUpload(): Promise<void>
    + handleReset(): void
    - validarArchivo(file, tipo): string | null
  }

  class TemplateSelector <<React.Component>> {
    - disenoSeleccionado: string
    - nivelSeleccionado: string
    - tipologiaSeleccionada: string
    - plantillaFinal: PlantillaOption | null
    ..
    + handleConfirmar(): void
    + handleReset(): void
    ' useMemo: disenos, niveles, tipologias, plantillaResultante
  }

  class MetadataForm <<React.Component>> {
    - courseOption: CourseOption
    - courseName: string
    - courseId: string
    - errors: Record<string, string>
    - confirmed: CourseMetadata | null
    ..
    + validar(): boolean
    + handleSubmit(): void
    + handleReset(): void
  }

  class ProgressTracker <<React.Component>> {
    - eventos: ProgressEventData[]
    - ultimo: ProgressEventData | null
    - conectando: boolean
    - errorConex: boolean
    - sourceRef: EventSource | null
    ..
    + useEffect: abre EventSource al montar
    + onRetry(): void
    + onNewDeploy(): void
  }

  class ApiClient <<Service axios>> {
    + {static} baseURL: string
    + {static} timeout: number
    ..
    + uploadZip(zipFile, excelFile?): Promise<UploadResponse>
    + startDeploy(params): Promise<DeployStartResponse>
    + openDeployStream(taskId, onEvent, onError): EventSource
    + checkHealth(): Promise<HealthResponse>
  }

}

' Composición del wizard
DeployPage "1" *-- "1" DropZone : compone (paso 1) >
DeployPage "1" *-- "1" TemplateSelector : compone (paso 2) >
DeployPage "1" *-- "1" MetadataForm : compone (paso 3) >
DeployPage "1" *-- "0..1" ProgressTracker : muestra al desplegar >

' Frontend → Backend
DeployPage --> ApiClient : usa >
DropZone --> ApiClient : uploadZip() >
ProgressTracker --> ApiClient : openDeployStream() >
ApiClient ..> DeployStartResponse : deserializa >

' =============================================================================
' NOTAS DE ARQUITECTURA
' =============================================================================

note top of DeploymentOrchestrator
  <b>Patrón Facade (GoF Estructural)</b>
  Único punto de entrada al proceso completo.
  El router nunca conoce los repositorios.
  Emite ProgressEvents como async generator
  para transmisión SSE en tiempo real.
end note

note right of IPageComposer
  <b>Patrón Strategy (GoF Comportamental)</b>
  Cada tipo de página tiene su propio
  algoritmo de composición HTML.
  PageComposerFactory selecciona la
  implementación correcta en runtime.
end note

note right of PageComposerFactory
  <b>Patrón Factory con Registry</b>
  Desacopla el orquestador de las
  implementaciones concretas.
  Extensible sin modificar código
  existente (principio OCP).
end note

note bottom of CourseRepository
  <b>Patrón Repository (GoF)</b>
  Abstrae el protocolo REST de Canvas.
  El orquestador trabaja con conceptos
  de dominio, no con HTTP directamente.
end note

note bottom of TaskManager
  <b>Mensajería in-process</b>
  asyncio.Queue conecta el
  BackgroundTask (orquestador) con
  el endpoint SSE (streaming).
end note

@enduml
